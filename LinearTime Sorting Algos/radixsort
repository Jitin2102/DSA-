#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

void CountingSort(vector<int>& arr, int exp) {
    int n = arr.size();
    vector<int> res(n, 0);
    vector<int> cnt(10, 0);

    for (int i = 0; i < n; i++)
        cnt[(arr[i] / exp) % 10]++;

    for (int i = 1; i < 10; i++)
        cnt[i] += cnt[i - 1];

    for (int i = n - 1; i >= 0; i--) {
        int digit = (arr[i] / exp) % 10;
        res[cnt[digit] - 1] = arr[i];
        cnt[digit]--;
    }

    for (int i = 0; i < n; i++)
        arr[i] = res[i];
}

void RadixSort(vector<int>& arr) {
    if (arr.empty()) return;
    int maxV = *max_element(arr.begin(), arr.end());
    for (int exp = 1; maxV / exp > 0; exp *= 10)
        CountingSort(arr, exp);
}

void RadixSortWithNegatives(vector<int>& arr) {
    vector<int> neg, pos;
    for (int x : arr) {
        if (x < 0) neg.push_back(-x); // store absolute
        else pos.push_back(x);
    }

    // Sort positives
    RadixSort(pos);

    // Sort negatives (as positives), then reverse
    RadixSort(neg);
    for (int& x : neg) x = -x;
    reverse(neg.begin(), neg.end());

    // Merge
    arr.clear();
    arr.insert(arr.end(), neg.begin(), neg.end());
    arr.insert(arr.end(), pos.begin(), pos.end());
}

int main() {
    vector<int> arr = {2, -5, 3, 0, -2, 3, 0, -3};
    RadixSortWithNegatives(arr);
    for (int x : arr) cout << x << " ";
    return 0;
}
